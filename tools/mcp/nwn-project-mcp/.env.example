# NWN:EE installation root (contains data/, bin/, etc.)
NWN_ROOT=/path/to/NeverwinterNights/NWN

# NWN user data folder (contains modules/, hak/, override/, etc.)
NWN_HOME=/path/to/Documents/Neverwinter Nights

# Nasher binary path (if not on PATH)
# NASHER_BIN=nasher

# nwnsc binary path (if not on PATH)
# NWNSC_BIN=nwnsc

# Aurora Toolset binary path (Windows only)
# AURORA_BIN=C:/NeverwinterNights/bin/win32/nwtoolset.exe

# Set to true to allow installing built artifacts to NWN_HOME
ALLOW_INSTALL_TO_NWN_HOME=false

# Set to true to allow starting NWNX server
ALLOW_START_SERVER=false
