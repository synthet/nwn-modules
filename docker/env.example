# Copy to docker/.env and adjust for local/private deployments.
# Do not commit secrets here; keep passwords/tokens in docker/.env or a secret manager.
# Lines marked SECRET must be overridden in docker/.env before staging or production use.

# NWN server image.
# For staging/production, pin to an immutable digest:
#   NWN_SERVER_IMAGE=ghcr.io/nwnxee/unified@sha256:<digest>
# Run 'docker pull ghcr.io/nwnxee/unified:latest' then 'docker inspect ...' to get the digest.
NWN_SERVER_IMAGE=ghcr.io/nwnxee/unified:latest

# NWN server identity and content
NWN_SERVER_NAME=Starter Module Private PW
NWN_MODULE_NAME=starter_module
NWN_MODULE_FILE=starter_module.mod

# Host ports
NWN_SERVER_PORT=5121
NWSYNC_HTTP_PORT=8080

# Database connection (passwords belong in docker/.env, not this example file)
DATABASE_HOST=db
DATABASE_NAME=nwn_persistent_world
DATABASE_PORT=5432
DATABASE_USER=nwn
# SECRET: override DATABASE_PASSWORD in docker/.env
DATABASE_PASSWORD=change-me-local-only

# NWSync URL advertised to clients when joining the server
NWSYNC_URL=http://localhost:8080/nwsync/
