# Copy to docker/.env and adjust for local/private deployments.
# Do not commit secrets here; keep passwords/tokens in docker/.env or a secret manager.

# NWN server identity and content
NWN_SERVER_NAME=Starter Module Private PW
NWN_MODULE_NAME=starter_module
NWN_MODULE_FILE=starter_module.mod

# Host ports
NWN_SERVER_PORT=5121
NWSYNC_HTTP_PORT=8080

# Database connection metadata (passwords belong in docker/.env, not this example file)
DATABASE_HOST=db
DATABASE_NAME=nwn_persistent_world
DATABASE_PORT=5432
DATABASE_USER=nwn

# NWSync/static hosting URL advertised to clients when serving from this stack
NWSYNC_URL=http://localhost:8080/nwsync/
