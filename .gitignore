# Nasher per-user config — intentionally excluded per Nasher docs
user.cfg
*.user.cfg

# Generated NWN build artifacts — distribute via Releases, not Git
build/dist/*.mod
build/dist/*.hak
build/dist/*.tlk
*.mod
*.hak
*.erf
*.tlk
*.ncs

# Nasher temp and cache
.nasher/
nasher-temp/

# NWN user-folder installed files (NWN_HOME paths)
# These are runtime installs, not source
modules/
hak/
tlk/
override/

# Local NWN install paths that should not be committed
Neverwinter Nights/
nwn_home/
nwn_root/

# Art source files that are too large for Git (commit exports only)
art/textures/*.psd
art/textures/*.xcf
art/textures/*.kra

# OS noise
.DS_Store
Thumbs.db

# Editor temp files and IDE project files
*.tmp
*~
.vscode/
.idea/

# Docker deployment environment files may contain secrets
docker/.env
docker/.env.*
!docker/env.example

# MCP server build output
tools/mcp/nwn-project-mcp/dist/
tools/mcp/nwn-project-mcp/node_modules/

# Python test artifacts
__pycache__/
*.pyc
.pytest_cache/
