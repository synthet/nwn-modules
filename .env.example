# Copy to .env and adjust for your machine. .env is git-ignored.

# Third-party modding tools (Nasher, nwnsc, NWNT, NWNX, …)
NWN_TOOLS=D:/Projects/nwn-tools

# NWN:EE game install (contains Aurora Toolset binaries)
NWN_ROOT=D:/Games/NeverwinterNightsEE

# NWN user folder (modules/, hak/, override/, …)
NWN_HOME=D:/Documents/Neverwinter Nights
